{
  "name": "claudekit",
  "version": "0.1.0",
  "description": "ClaudeKit - Claude Code 桌面管理工具",
  "main": "./out/main/index.js",
  "author": "deajax",
  "license": "MIT",
  "build": {
    "appId": "com.claudekit.app",
    "productName": "ClaudeKit",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "deajax",
      "repo": "ClaudeKit"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ]
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --config",
    "publish": "electron-vite build && electron-builder --config --publish always",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null; exit 0"
  },
  "dependencies": {
    "ant-design-vue": "^4.2.6",
    "fs-extra": "^11.2.0",
    "marked": "^18.0.2",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "pinia": "^2.3.0",
    "sudo-prompt": "^9.2.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@remixicon/vue": "^4.9.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vueuse/core": "^11.3.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "less": "^4.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^5.4.11",
    "vue-tsc": "^2.2.0"
  }
}
