{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["electron-vite/node"]
  },
  "include": [
    "electron/**/*.ts",
    "electron.vite.config.ts",
    "shared/**/*.ts"
  ]
}
